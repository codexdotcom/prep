generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  // url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String?   @unique
  phone           String?   @unique
  emailVerified   DateTime?
  hashedPassword  String?
  image           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  profile         StudentProfile?
  diagnosticResults DiagnosticResult[]
  testSessions    TestSession[]
  studyPlans      StudyPlan[]
  studyStreak     StudyStreak?
   achievements     UserAchievement[]
  xp               UserXP?
  xpTransactions   XPTransaction[]
  dailyMissions    DailyMission[]
  leaderboardEntries LeaderboardEntry[]
   subscription     Subscription?
  payments         Payment[]
  flaggedQuestions  FlaggedQuestion[]
  microInteractions MicroInteraction[]
  realityChecks    RealityCheck[]
   referralsMade       Referral[]   @relation("referralsMade")
  referredBy          Referral?    @relation("referredBy")
  referralCode        ReferralCode?
  challengeAttempts   DailyChallengeAttempt[]
  whatsappSession  WhatsAppSession[]
    parentLinks      ParentLink[]
     noteViews       NoteView[]
  noteUploads     NoteUpload[]
  schoolEnrollment SchoolEnrollment?
  careerProfile    CareerProfile?
    universityMatches   UniversityMatch[]
  ambassador          Ambassador?
  ambassadorRecruits  AmbassadorRecruit[] @relation("AmbassadorRecruits")
  adminCenters        TutorialCenter[]    @relation("CenterAdmin")
  centerTeacher       CenterTeacher[]
  centerStudent       CenterStudent[]
  postUtmeSessions   PostUtmeSession[]
  admissionTrackers  AdmissionTracker[]
  topicAbilities    StudentTopicAbility[]
  tutorProfile       TutorProfile?
  studentSessions    TutorSession[]  @relation("StudentSessions")
  studentReviews     TutorReview[]   @relation("StudentReviews")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model StudentProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  firstName       String
  lastName        String
  displayName     String?
  dateOfBirth     DateTime?
  gender          Gender?
  state           String?            // Nigerian state
  city            String?
  schoolName      String?
  schoolType      SchoolType?
  classLevel      ClassLevel?

  // JAMB-specific
  examYear        Int
  targetScore     Int                // e.g. 250, 300, 350
  jambSubjects    JambSubjectChoice[]
  preferredCourse String?            // desired university course
  preferredUni    String?            // first-choice university

  // Learning preferences (feeds ML models)
  studyHoursPerDay   Float?          // how many hours they can commit
  preferredTimeSlot  TimeSlot?
  learningStyle      LearningStyle?
  previousJambScore  Int?            // if they've written before
  mockTestsCompleted Int             @default(0)

  // ML feature columns
  onboardingCompletedAt DateTime?
  diagnosticCompletedAt DateTime?
  riskLevel             RiskLevel?   // computed after diagnostic

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model JambSubjectChoice {
  id        String @id @default(cuid())
  profileId String
  subject   JambSubject
  priority  Int                      // 1-4 (Use of English is always 1)

  profile StudentProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, subject])
}

model DiagnosticResult {
  id              String   @id @default(cuid())
  userId          String
  subject         JambSubject
  totalQuestions  Int
  correctAnswers  Int
  averageTimeMs   Int               // avg milliseconds per question
  topicBreakdown  Json              // { topicId: { correct, total, avgTime } }
  weakTopics      String[]          // topic IDs flagged as weak
  strongTopics    String[]
  carelessErrors  Int               // correct concept but wrong answer
  predictedScore  Float?            // ML-predicted JAMB score for subject
  rawResponses    Json              // full response data for retraining
  completedAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, subject])
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum SchoolType {
  PUBLIC
  PRIVATE
  FEDERAL_GOVERNMENT
  STATE_GOVERNMENT
  INTERNATIONAL
  HOME_SCHOOL
}

enum ClassLevel {
  SS1
  SS2
  SS3
  GRADUATE
  GAP_YEAR
}

enum TimeSlot {
  EARLY_MORNING    // 5am - 8am
  MORNING          // 8am - 12pm
  AFTERNOON        // 12pm - 4pm
  EVENING          // 4pm - 8pm
  NIGHT            // 8pm - 12am
  LATE_NIGHT       // 12am - 5am
}

enum LearningStyle {
  VISUAL
  READING
  PRACTICE
  MIXED
}

enum RiskLevel {
  HIGH             // likely below 200
  MEDIUM           // 200-250 range
  LOW              // 250+ likely
  VERY_LOW         // 300+ likely
}

enum JambSubject {
  USE_OF_ENGLISH
  MATHEMATICS
  PHYSICS
  CHEMISTRY
  BIOLOGY
  LITERATURE
  GOVERNMENT
  ECONOMICS
  COMMERCE
  ACCOUNTING
  CRS
  IRS
  GEOGRAPHY
  AGRICULTURAL_SCIENCE
  HISTORY
  CIVIC_EDUCATION
  COMPUTER_STUDIES
  FINE_ARTS
  MUSIC
  ARABIC
  FRENCH
  HAUSA
  IGBO
  YORUBA
}
// ── Question Bank Models ──

model Topic {
  id          String      @id @default(cuid())
  subject     JambSubject
  name        String                // e.g. "Comprehension", "Quadratic Equations"
  slug        String      @unique
  description String?
  weight      Float       @default(1.0)  // how often this appears in real JAMB
  sortOrder   Int         @default(0)

  questions   Question[]
  subtopics   Subtopic[]
  studyPlans      StudyPlan[]
  microContent    MicroContent[]
  dailyChallenges     DailyChallenge[]
  generatedNotes  GeneratedNote[]
studentAbilities  StudentTopicAbility[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([subject])
}

model Subtopic {
  id        String   @id @default(cuid())
  topicId   String
  name      String
  slug      String   @unique
  sortOrder Int      @default(0)

  topic     Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  questions Question[]

  @@index([topicId])
}

model Question {
  id              String         @id @default(cuid())
  subject         JambSubject
  topicId         String
  subtopicId      String?
  year            Int?                    // JAMB year if from past paper
  questionNumber  Int?                    // original question number

  body            String         @db.Text // the question text (supports markdown)
  imageUrl        String?                 // optional diagram/figure
  optionA         String
  optionB         String
  optionC         String
  optionD         String
  correctOption   CorrectOption           // A, B, C, or D
  explanation     String?        @db.Text // AI-generated or human explanation
  difficulty      Difficulty     @default(MEDIUM)
  isActive        Boolean        @default(true)

  // ML feature columns
  avgTimeMs       Int?                    // average time students take
  correctRate     Float?                  // % of students who get it right
  discriminationIndex Float?              // how well it separates strong/weak students
  totalAttempts   Int            @default(0)

  topic           Topic          @relation(fields: [topicId], references: [id])
  subtopic        Subtopic?      @relation(fields: [subtopicId], references: [id])
  responses       QuestionResponse[]
   flags            FlaggedQuestion[]
 explanationImageUrl String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([subject, topicId])
  @@index([subject, difficulty])
  @@index([year, subject])
}

model TestSession {
  id              String          @id @default(cuid())
  userId          String
  mode            TestMode
  subject         JambSubject?             // null for full mock
  subjects        JambSubject[]            // for full mock (4 subjects)
  totalQuestions  Int
  timeLimit       Int                      // seconds
  status          TestStatus      @default(IN_PROGRESS)

  // Results (populated on submit)
  score           Int?
  totalCorrect    Int?
  totalWrong      Int?
  totalSkipped    Int?
  timeTaken       Int?                     // actual seconds used
  percentile      Float?                   // vs other students

  // ML metadata
  difficultyProfile Json?                  // { easy: n, medium: n, hard: n }
  topicAccuracy     Json?                  // { topicId: { correct, total } }
  timeDistribution  Json?                  // { questionId: ms }
  flaggedQuestions  String[]               // question IDs student flagged

  startedAt       DateTime        @default(now())
  completedAt     DateTime?
  createdAt       DateTime        @default(now())

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  responses       QuestionResponse[]

  @@index([userId, status])
  @@index([userId, mode])
}

model QuestionResponse {
  id            String        @id @default(cuid())
  sessionId     String
  questionId    String
  userId        String

  selectedOption CorrectOption?           // null if skipped
  isCorrect     Boolean?
  timeSpent     Int                       // milliseconds on this question
  isFlagged     Boolean       @default(false)
  confidence    Int?                      // 1-5 self-rated confidence (future feature)

  answeredAt    DateTime      @default(now())

  session       TestSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question      Question      @relation(fields: [questionId], references: [id])

  @@unique([sessionId, questionId])
  @@index([userId, questionId])
}

enum CorrectOption {
  A
  B
  C
  D
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum TestMode {
  PRACTICE         // untimed, single subject
  TIMED            // timed, single subject
  MOCK_EXAM        // full JAMB simulation (4 subjects)
  TOPIC_DRILL      // specific topic focus
  WEAK_TOPIC       // AI-selected weak areas
  DIAGNOSTIC       // initial assessment
}

enum TestStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
  TIMED_OUT
}

model StudyPlan {
  id            String       @id @default(cuid())
  userId        String
  date          DateTime     @db.Date
  subject       JambSubject
  topicId       String
  taskType      StudyTaskType
  title         String
  description   String?
  questionCount Int          @default(10)
  difficulty    Difficulty   @default(MEDIUM)
  priority      Int          @default(0)     // higher = more important
  status        StudyStatus  @default(PENDING)
  completedAt   DateTime?

  // Spaced repetition fields
  repetitionNumber Int       @default(0)
  easeFactor       Float     @default(2.5)
  intervalDays     Int       @default(1)
  nextReviewDate   DateTime?

  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic         Topic        @relation(fields: [topicId], references: [id])

  createdAt     DateTime     @default(now())

  @@index([userId, date])
  @@index([userId, status])
  @@index([userId, nextReviewDate])
}

model StudyStreak {
  id          String   @id @default(cuid())
  userId      String   @unique
  currentStreak Int    @default(0)
  longestStreak Int    @default(0)
  lastStudyDate DateTime?
  totalStudyDays Int   @default(0)

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum StudyTaskType {
  WEAK_TOPIC_DRILL
  REVIEW
  SPACED_REPETITION
  NEW_TOPIC
  MOCK_PREP
  SPEED_DRILL
}

enum StudyStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
}


model Achievement {
  id          String   @id @default(cuid())
  key         String   @unique        // e.g. "first_test", "streak_7"
  title       String
  description String
  icon        String                  // emoji or icon name
  category    AchievementCategory
  requirement Int                     // threshold value
  xpReward    Int      @default(0)

  unlocks     UserAchievement[]

  @@index([category])
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime    @default(now())
  seen          Boolean     @default(false)

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id])

  @@unique([userId, achievementId])
  @@index([userId])
}

model UserXP {
  id          String   @id @default(cuid())
  userId      String   @unique
  totalXP     Int      @default(0)
  level       Int      @default(1)
  weeklyXP    Int      @default(0)
  monthlyXP   Int      @default(0)
  lastResetAt DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model XPTransaction {
  id        String   @id @default(cuid())
  userId    String
  amount    Int
  source    XPSource
  sourceId  String?           // test session ID, study plan ID, etc.
  note      String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model DailyMission {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime @db.Date
  missionType MissionType
  title       String
  description String
  target      Int                   // e.g. 20 questions, 1 test
  progress    Int      @default(0)
  xpReward    Int      @default(0)
  status      MissionStatus @default(ACTIVE)
  completedAt DateTime?

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@unique([userId, date, missionType])
}

model LeaderboardEntry {
  id        String          @id @default(cuid())
  userId    String
  period    LeaderboardPeriod
  periodKey String                   // e.g. "2026-W22", "2026-01"
  score     Int             @default(0)
  rank      Int?

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, period, periodKey])
  @@index([period, periodKey, score])
}

enum AchievementCategory {
  MILESTONE
  STREAK
  ACCURACY
  SPEED
  SOCIAL
  MASTERY
}

enum XPSource {
  TEST_COMPLETE
  QUESTION_CORRECT
  STREAK_BONUS
  DAILY_MISSION
  ACHIEVEMENT
  STUDY_PLAN
  FIRST_LOGIN
}

enum MissionType {
  ANSWER_QUESTIONS
  COMPLETE_TEST
  STUDY_MINUTES
  PERFECT_TOPIC
  USE_TUTOR
  REVIEW_WEAK
}

enum MissionStatus {
  ACTIVE
  COMPLETED
  EXPIRED
}

enum LeaderboardPeriod {
  WEEKLY
  MONTHLY
  ALL_TIME
}

model Subscription {
  id              String           @id @default(cuid())
  userId          String           @unique
  plan            SubscriptionPlan @default(FREE)
  status          SubscriptionStatus @default(ACTIVE)
  paystackCustomerId String?
  paystackSubscriptionCode String?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelledAt     DateTime?

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments        Payment[]

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([userId])
  @@index([status])
}

model Payment {
  id              String        @id @default(cuid())
  userId          String
  subscriptionId  String?
  amount          Int                        // in kobo (₦1 = 100 kobo)
  currency        String        @default("NGN")
  status          PaymentStatus @default(PENDING)
  provider        String        @default("paystack")
  providerRef     String?       @unique      // paystack reference
  providerTxId    String?                    // paystack transaction ID
  plan            SubscriptionPlan?
  metadata        Json?

  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription    Subscription? @relation(fields: [subscriptionId], references: [id])

  createdAt       DateTime      @default(now())

  @@index([userId])
  @@index([providerRef])
}

model FlaggedQuestion {
  id          String     @id @default(cuid())
  questionId  String
  userId      String
  reason      FlagReason
  description String?
  status      FlagStatus @default(OPEN)
  resolvedBy  String?
  resolvedAt  DateTime?
  resolution  String?

  question    Question   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime   @default(now())

  @@index([status])
  @@index([questionId])
}

enum SubscriptionPlan {
  FREE
  STARTER         // ₦1,500/month
  PRO             // ₦3,000/month
  ELITE           // ₦5,000/month
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  EXPIRED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum FlagReason {
  WRONG_ANSWER
  UNCLEAR_QUESTION
  DUPLICATE
  OUTDATED
  TYPO
  OTHER
}

enum FlagStatus {
  OPEN
  REVIEWING
  RESOLVED
  DISMISSED
}

model MicroContent {
  id          String           @id @default(cuid())
  type        MicroContentType
  subject     JambSubject
  topicId     String?
  title       String
  body        String           @db.Text
  imageUrl    String?
  tags        String[]
  difficulty  Difficulty       @default(MEDIUM)
  isActive    Boolean          @default(true)
  sortOrder   Int              @default(0)

  // Engagement stats
  views       Int              @default(0)
  likes       Int              @default(0)
  saves       Int              @default(0)

  topic       Topic?           @relation(fields: [topicId], references: [id])
  interactions MicroInteraction[]

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([subject, isActive])
  @@index([type, isActive])
}

model MicroInteraction {
  id          String   @id @default(cuid())
  userId      String
  contentId   String
  liked       Boolean  @default(false)
  saved       Boolean  @default(false)
  viewed      Boolean  @default(true)
  viewDuration Int     @default(0)         // seconds spent on card

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content     MicroContent @relation(fields: [contentId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@unique([userId, contentId])
  @@index([userId])
}

enum MicroContentType {
  TRICK           // quick math/science trick
  MNEMONIC        // memory device
  TRAP            // common JAMB trap question pattern
  FLASHCARD       // term + definition
  HACK            // exam strategy tip
  FACT            // "did you know" engaging fact
  FORMULA         // key formula with visual
  MISTAKE         // "most students get this wrong"
}

model University {
  id              String   @id @default(cuid())
  name            String
  shortName       String   @unique        // e.g. "UNILAG"
  state           String
  type            UniType
  isActive        Boolean  @default(true)

  courses         Course[]
    matches             UniversityMatch[]
 postUtmeExams      PostUtmeExam[]
  admissionTrackers  AdmissionTracker[]
  @@index([state])
}

model Course {
  id              String   @id @default(cuid())
  universityId    String
  name            String
  faculty         String?
  jambCutoff      Int                      // minimum JAMB score
  departmentalCutoff Int?                  // post-UTME cutoff if known
  requiredSubjects JambSubject[]           // subjects needed
  competitiveness Competitiveness @default(MODERATE)
  acceptanceRate  Float?                   // estimated %
  totalSlots      Int?                     // estimated yearly intake
  isActive        Boolean  @default(true)

  university      University @relation(fields: [universityId], references: [id], onDelete: Cascade)
  realityChecks   RealityCheck[]
   matches             UniversityMatch[]
   admissionTrackers  AdmissionTracker[]

  @@unique([universityId, name])
  @@index([universityId])
  @@index([jambCutoff])
}

model RealityCheck {
  id                String   @id @default(cuid())
  userId            String
  courseId           String
  predictedScore    Int
  targetScore       Int
  probability       Float              // 0-100%
  gap               Int                // points needed
  roadmap           Json?              // generated study roadmap
  subjectBreakdown  Json?              // per-subject analysis
  generatedAt       DateTime @default(now())

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course            Course   @relation(fields: [courseId], references: [id])

  @@index([userId])
  @@index([userId, courseId])
}

enum UniType {
  FEDERAL
  STATE
  PRIVATE
}

enum Competitiveness {
  LOW
  MODERATE
  HIGH
  VERY_HIGH
  EXTREME
}


model Referral {
  id              String        @id @default(cuid())
  referrerId      String
  referredId      String        @unique
  referralCode    String
  status          ReferralStatus @default(PENDING)
  rewardClaimed   Boolean       @default(false)
  completedAt     DateTime?

  referrer        User          @relation("referralsMade", fields: [referrerId], references: [id], onDelete: Cascade)
  referred        User          @relation("referredBy", fields: [referredId], references: [id], onDelete: Cascade)

  createdAt       DateTime      @default(now())

  @@index([referrerId])
  @@index([referralCode])
}

model ReferralCode {
  id        String   @id @default(cuid())
  userId    String   @unique
  code      String   @unique
  uses      Int      @default(0)

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([code])
}

model DailyChallenge {
  id              String   @id @default(cuid())
  date            DateTime @unique @db.Date
  subject         JambSubject
  topicId         String?
  title           String
  description     String
  questionIds     String[]            // 5-10 curated question IDs
  difficulty      Difficulty @default(MEDIUM)
  timeLimit       Int      @default(300)  // seconds
  xpReward        Int      @default(50)
  bonusXP         Int      @default(25)   // for top 10%

  topic           Topic?   @relation(fields: [topicId], references: [id])
  attempts        DailyChallengeAttempt[]

  createdAt       DateTime @default(now())
}

model DailyChallengeAttempt {
  id              String   @id @default(cuid())
  userId          String
  challengeId     String
  score           Int                     // correct count
  totalQuestions  Int
  timeTaken       Int                     // seconds
  accuracy        Float
  rank            Int?
  xpEarned        Int      @default(0)
  responses       Json                    // { questionId: selectedOption }

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge       DailyChallenge @relation(fields: [challengeId], references: [id])

  completedAt     DateTime @default(now())

  @@unique([userId, challengeId])
  @@index([challengeId, accuracy])
}

enum ReferralStatus {
  PENDING
  COMPLETED        // referred user completed onboarding
  REWARDED          // referrer got their reward
}



model WhatsAppSession {
  id            String   @id @default(cuid())
  phone         String   @unique
  userId        String?
  state         WAState  @default(IDLE)
  context       Json?                  // current quiz state, pending question, etc.
  lastMessageAt DateTime @default(now())

  user          User?    @relation(fields: [userId], references: [id])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([phone])
  @@index([userId])
}

enum WAState {
  IDLE
  ONBOARDING_NAME
  ONBOARDING_SUBJECTS
  QUIZ_ACTIVE
  WAITING_ANSWER
  ASKING_AI
}

// ─── Parent Dashboard ───
model ParentLink {
  id            String   @id @default(cuid())
  parentEmail   String
  studentId     String
  status        ParentLinkStatus @default(PENDING)
  accessCode    String   @unique
  lastViewedAt  DateTime?

  student       User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())

  @@unique([parentEmail, studentId])
  @@index([parentEmail])
  @@index([accessCode])
}

enum ParentLinkStatus {
  PENDING
  ACTIVE
  REVOKED
}

// ─── School Dashboard ───
model School {
  id            String   @id @default(cuid())
  name          String
  code          String   @unique
  state         String
  type          SchoolType
  adminEmail    String
  adminName     String
  plan          SchoolPlan @default(FREE)
  maxStudents   Int      @default(50)
  isActive      Boolean  @default(true)

  enrollments   SchoolEnrollment[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([state])
  @@index([code])
}

model SchoolEnrollment {
  id        String   @id @default(cuid())
  schoolId  String
  userId    String   @unique
  role      SchoolRole @default(STUDENT)
  joinedAt  DateTime @default(now())

  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([schoolId, userId])
  @@index([schoolId])
}

enum SchoolPlan {
  FREE
  BASIC
  PREMIUM
  ENTERPRISE
}

enum SchoolRole {
  STUDENT
  TEACHER
  ADMIN
}

// ─── Scholarship ───
model Scholarship {
  id            String   @id @default(cuid())
  name          String
  provider      String
  description   String   @db.Text
  amount        String?
  currency      String   @default("NGN")
  deadline      DateTime?
  eligibility   Json
  url           String?
  states        String[]
  courses       String[]
  minScore      Int?
  maxScore      Int?
  isActive      Boolean  @default(true)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isActive])
}

// ─── Career Discovery ───
model CareerProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  interests     String[]
  strengths     String[]
  preferredStyle String?
  suggestedCareers Json?
  suggestedCourses Json?
  completedAt   DateTime?

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model GeneratedNote {
  id            String   @id @default(cuid())
  subject       JambSubject
  topicId       String
  title         String
  content       String   @db.Text    // markdown with math
  summary       String?  @db.Text    // TL;DR version
  keyFormulas   String[] 
  commonMistakes String[]
  examTips      String[]
  questionCount Int      @default(0)  // how many questions were analyzed
  difficulty    Difficulty @default(MEDIUM)
  version       Int      @default(1)
  isPublished   Boolean  @default(false)
  generatedFrom Json?                 // { questionIds: [], uploadedFiles: [] }

  topic         Topic    @relation(fields: [topicId], references: [id])
  views         NoteView[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([subject, topicId, version])
  @@index([subject, isPublished])
  @@index([topicId])
}

model NoteView {
  id         String   @id @default(cuid())
  userId     String
  noteId     String
  viewedAt   DateTime @default(now())
  timeSpent  Int      @default(0)
  bookmarked Boolean  @default(false)

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  note       GeneratedNote @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@unique([userId, noteId])
  @@index([userId])
  @@index([userId, bookmarked])
}
model NoteUpload {
  id          String   @id @default(cuid())
  userId      String
  subject     JambSubject
  topicId     String?
  filename    String
  fileType    String
  fileData    String   @db.Text     // base64
  processed   Boolean  @default(false)
  extractedText String? @db.Text

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([subject])
}

// ─── University Match Engine ───
model UniversityMatch {
  id            String   @id @default(cuid())
  userId        String
  universityId  String
  courseId       String
  action        MatchAction
  matchScore    Int      @default(0)

  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  university    University @relation(fields: [universityId], references: [id], onDelete: Cascade)
  course        Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())

  @@unique([userId, universityId, courseId])
  @@index([userId, action])
}

enum MatchAction {
  LIKED
  SKIPPED
  SAVED
}

model Ambassador {
  id              String   @id @default(cuid())
  userId          String   @unique
  code            String   @unique
  displayName     String?
  schoolName      String
  schoolState     String
  schoolCity      String?
  schoolType      SchoolType @default(PRIVATE)
  tier            AmbassadorTier @default(STARTER)
  isSchoolCaptain Boolean  @default(false)
  bio             String?  @db.Text

  // Stats
  totalSignups      Int    @default(0)
  verifiedReferrals Int    @default(0)  // completed profile + first test
  premiumConversions Int   @default(0)  // upgraded to paid
  totalEarnings     Int    @default(0)  // lifetime in Naira
  pendingPayout     Int    @default(0)
  monthlyReferrals  Int    @default(0)  // reset monthly
  monthlyEarnings   Int    @default(0)  // reset monthly

  isActive        Boolean  @default(true)
  approvedAt      DateTime?
  lastActiveAt    DateTime?

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recruits        AmbassadorRecruit[]
  payouts         AmbassadorPayout[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([code])
  @@index([schoolState])
  @@index([tier])
  @@index([verifiedReferrals])
  @@index([totalEarnings])
}

model AmbassadorRecruit {
  id              String   @id @default(cuid())
  ambassadorId    String
  recruitUserId   String   @unique
  status          RecruitStatus @default(SIGNED_UP)

  // Milestones
  profileCompleted  Boolean @default(false)
  firstTestTaken    Boolean @default(false)
  upgradedToPremium Boolean @default(false)

  // Earnings from this recruit
  signupPaid        Boolean @default(false)
  verifiedPaid      Boolean @default(false)
  premiumPaid       Boolean @default(false)
  totalEarned       Int     @default(0)

  convertedAt     DateTime?
  upgradedAt      DateTime?

  ambassador      Ambassador @relation(fields: [ambassadorId], references: [id], onDelete: Cascade)
  recruitUser     User       @relation("AmbassadorRecruits", fields: [recruitUserId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([ambassadorId])
  @@index([status])
}

model AmbassadorPayout {
  id            String   @id @default(cuid())
  ambassadorId  String
  amount        Int
  method        String   @default("bank_transfer")
  bankName      String?
  accountNumber String?
  accountName   String?
  reference     String?
  status        PayoutStatus @default(PENDING)
  processedAt   DateTime?
  note          String?

  ambassador    Ambassador @relation(fields: [ambassadorId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())

  @@index([ambassadorId])
  @@index([status])
}

model AmbassadorChallenge {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  month       Int
  year        Int
  prize1      Int      @default(100000)
  prize2      Int      @default(50000)
  prize3      Int      @default(25000)
  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())

  @@unique([month, year])
}

enum AmbassadorTier {
  STARTER
  BRONZE
  SILVER
  GOLD
  DIAMOND
  LEGEND
}

enum RecruitStatus {
  SIGNED_UP
  PROFILED
  VERIFIED
  ACTIVE
  SUBSCRIBED
  CHURNED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}



// ─── Tutorial Center Portals ───
model TutorialCenter {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  state         String
  city          String?
  address       String?
  phone         String?
  email         String
  logoUrl       String?
  brandColor    String   @default("#22c55e")
  plan          CenterPlan @default(BASIC)
  maxStudents   Int      @default(50)
  isActive      Boolean  @default(true)

  adminId       String
  admin         User     @relation("CenterAdmin", fields: [adminId], references: [id])
  teachers      CenterTeacher[]
  students      CenterStudent[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([slug])
  @@index([state])
  @@index([adminId])
}

model CenterTeacher {
  id        String   @id @default(cuid())
  centerId  String
  userId    String
  role      String   @default("teacher")

  center    TutorialCenter @relation(fields: [centerId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  joinedAt  DateTime @default(now())

  @@unique([centerId, userId])
}

model CenterStudent {
  id        String   @id @default(cuid())
  centerId  String
  userId    String
  joinCode  String?

  center    TutorialCenter @relation(fields: [centerId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  joinedAt  DateTime @default(now())

  @@unique([centerId, userId])
  @@index([centerId])
}

enum CenterPlan {
  BASIC
  STANDARD
  PREMIUM
  ENTERPRISE
}


// ─── Post-UTME Preparation ───
model PostUtmeExam {
  id            String   @id @default(cuid())
  universityId  String
  year          Int
  course        String?
  duration      Int      @default(60) // minutes
  totalQuestions Int     @default(50)
  isActive      Boolean  @default(true)

  university    University @relation(fields: [universityId], references: [id], onDelete: Cascade)
  questions     PostUtmeQuestion[]
  sessions      PostUtmeSession[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([universityId, year, course])
  @@index([universityId])
}

model PostUtmeQuestion {
  id            String   @id @default(cuid())
  examId        String
  subject       String
  body          String   @db.Text
  imageUrl      String?
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correctOption String
  explanation   String?  @db.Text
  difficulty    Difficulty @default(MEDIUM)

  exam          PostUtmeExam @relation(fields: [examId], references: [id], onDelete: Cascade)
  responses     PostUtmeResponse[]

  createdAt     DateTime @default(now())

  @@index([examId])
}

model PostUtmeSession {
  id            String   @id @default(cuid())
  userId        String
  examId        String
  score         Int?
  totalAnswered Int      @default(0)
  totalCorrect  Int      @default(0)
  startedAt     DateTime @default(now())
  completedAt   DateTime?
  status        TestStatus @default(IN_PROGRESS)

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam          PostUtmeExam @relation(fields: [examId], references: [id])
  responses     PostUtmeResponse[]

  @@index([userId])
  @@index([examId])
}

model PostUtmeResponse {
  id            String   @id @default(cuid())
  sessionId     String
  questionId    String
  selectedOption String?
  isCorrect     Boolean  @default(false)
  timeSpent     Int      @default(0)

  session       PostUtmeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question      PostUtmeQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  answeredAt    DateTime @default(now())

  @@unique([sessionId, questionId])
}

// ─── Admission Tracking ───
model AdmissionTracker {
  id              String   @id @default(cuid())
  userId          String
  universityId    String
  courseId         String
  jambScore       Int?
  postUtmeScore   Int?
  oLevelGrades    Json?     // { "MATHEMATICS": "A1", "ENGLISH": "B2", ... }
  status          AdmissionStatus @default(AWAITING_RESULTS)
  jambRegNumber   String?
  notes           String?  @db.Text
  screeningDate   DateTime?
  resultDate      DateTime?
  lastChecked     DateTime?

  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  university      University @relation(fields: [universityId], references: [id])
  course          Course     @relation(fields: [courseId], references: [id])
  updates         AdmissionUpdate[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, universityId, courseId])
  @@index([userId])
  @@index([status])
}

model AdmissionUpdate {
  id          String   @id @default(cuid())
  trackerId   String
  title       String
  description String   @db.Text
  type        UpdateType @default(INFO)
  source      String?

  tracker     AdmissionTracker @relation(fields: [trackerId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@index([trackerId])
}

enum AdmissionStatus {
  AWAITING_RESULTS
  JAMB_SUBMITTED
  POST_UTME_SCHEDULED
  POST_UTME_COMPLETED
  SCREENING
  MERIT_LIST
  ADMITTED
  SUPPLEMENTARY
  NOT_ADMITTED
  DEFERRED
}

enum UpdateType {
  INFO
  MILESTONE
  WARNING
  ACTION_REQUIRED
}

// ─── Tutor Marketplace ───
model TutorProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  displayName     String
  bio             String   @db.Text
  subjects        String[]
  qualifications  String[]
  experience      String?
  hourlyRate      Int          // in Naira
  rating          Float        @default(0)
  totalReviews    Int          @default(0)
  totalSessions   Int          @default(0)
  isVerified      Boolean      @default(false)
  isAvailable     Boolean      @default(true)
  availableSlots  Json?        // { "monday": ["9:00", "10:00"], ... }
  state           String?
  avatarUrl       String?

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions        TutorSession[]
  reviews         TutorReview[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isAvailable, isVerified])
  @@index([rating])
}

model TutorSession {
  id            String   @id @default(cuid())
  tutorId       String
  studentId     String
  subject       String
  topic         String?
  scheduledAt   DateTime
  duration      Int      @default(60) // minutes
  status        SessionStatus @default(PENDING)
  meetingLink   String?
  amount        Int      @default(0) // Naira
  paymentRef    String?
  notes         String?  @db.Text
  cancelReason  String?

  tutor         TutorProfile @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  student       User         @relation("StudentSessions", fields: [studentId], references: [id], onDelete: Cascade)
  review        TutorReview?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tutorId])
  @@index([studentId])
  @@index([status])
}

model TutorReview {
  id          String   @id @default(cuid())
  sessionId   String   @unique
  tutorId     String
  studentId   String
  rating      Int      // 1-5
  comment     String?  @db.Text
  isPublic    Boolean  @default(true)

  session     TutorSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  tutor       TutorProfile @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  student     User         @relation("StudentReviews", fields: [studentId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@index([tutorId])
}

enum SessionStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

model StudentTopicAbility {
  id              String      @id @default(cuid())
  userId          String
  topicId         String
  subject         JambSubject

  ability         Float       @default(50)
  confidence      Float       @default(0)
  totalAttempts   Int         @default(0)
  totalCorrect    Int         @default(0)
  recentResults   Boolean[]               // last 10 answers (true/false)
  avgTimeMs       Int?
  lastPracticedAt DateTime?

  // Streak: positive = correct streak, negative = wrong streak
  currentStreak   Int         @default(0)

  // Spaced repetition
  intervalDays    Float       @default(1)
  easeFactor      Float       @default(2.5)
  nextReviewAt    DateTime?

  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic           Topic       @relation(fields: [topicId], references: [id])

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([userId, topicId])
  @@index([userId, subject])
  @@index([userId, nextReviewAt])
}